# =============================================================================
# DOCKER COMPOSE (desarrollo local)
# Copia a .env y rellena con Neon (Dashboard → Connect → JDBC).
# Usuario y contraseña VAN APARTE. La URL solo lleva host + database.
# Si la URL lleva ?, ponla entre comillas dobles por el carácter &.
# =============================================================================

# --- Vehicle ---
VEHICLE_DB_URL="jdbc:postgresql://ep-xxxx.us-east-1.aws.neon.tech/neondb?sslmode=require"
VEHICLE_DB_USERNAME=neondb_owner
VEHICLE_DB_PASSWORD=tu_password_neon

# --- Operation ---
OPERATION_DB_URL="jdbc:postgresql://ep-yyyy.us-east-1.aws.neon.tech/neondb?sslmode=require"
OPERATION_DB_USERNAME=neondb_owner
OPERATION_DB_PASSWORD=tu_password_neon


# =============================================================================
# RAILWAY (producción)
# Configura estas variables en el dashboard de Railway por cada servicio.
# Railway → Proyecto → Servicio → Variables
# Red privada interna: <nombre-servicio>.railway.internal
# =============================================================================

# ---------------------------------------------------------------------------
# Servicio: rental-vehicle  (Eureka — puerto 8761)
# Root Directory: /rental-vehicle
# En clientes usa ${{rental-vehicle...}} — mismo nombre que en Railway
# ---------------------------------------------------------------------------
PORT=8761
EUREKA_SERVER_URL=http://localhost:8761/eureka/

# ---------------------------------------------------------------------------
# Servicio: gateway  (puerto 8080)
# Solo dominio público en este servicio.
# ---------------------------------------------------------------------------
PORT=8080
EUREKA_CLIENT_SERVICEURL_DEFAULTZONE=http://${{rental-vehicle.RAILWAY_PRIVATE_DOMAIN}}:${{rental-vehicle.PORT}}/eureka

# ---------------------------------------------------------------------------
# Servicio: vehicle  (puerto 8091)
# Copiar solo este bloque en Variables → Raw Editor del servicio vehicle.
# URL sin usuario/contraseña (van en USERNAME y PASSWORD).
# ---------------------------------------------------------------------------
PORT=8091
EUREKA_CLIENT_SERVICEURL_DEFAULTZONE=http://${{rental-vehicle.RAILWAY_PRIVATE_DOMAIN}}:${{rental-vehicle.PORT}}/eureka
EUREKA_INSTANCE_HOSTNAME=${{RAILWAY_PRIVATE_DOMAIN}}
EUREKA_INSTANCE_PREFER_IP_ADDRESS=false
SPRING_DATASOURCE_URL=jdbc:postgresql://ep-royal-voice-apbh2usa.c-7.us-east-1.aws.neon.tech/neondb?sslmode=require
SPRING_DATASOURCE_USERNAME=neondb_owner
SPRING_DATASOURCE_PASSWORD=npg_Y0mCcLan8fjo

# ---------------------------------------------------------------------------
# Servicio: operation  (puerto 8092)
# Copiar solo este bloque en Variables → Raw Editor del servicio operation.
# ---------------------------------------------------------------------------
PORT=8092
EUREKA_CLIENT_SERVICEURL_DEFAULTZONE=http://${{rental-vehicle.RAILWAY_PRIVATE_DOMAIN}}:${{rental-vehicle.PORT}}/eureka
EUREKA_INSTANCE_HOSTNAME=${{RAILWAY_PRIVATE_DOMAIN}}
EUREKA_INSTANCE_PREFER_IP_ADDRESS=false
SPRING_DATASOURCE_URL=jdbc:postgresql://ep-rapid-lab-ap0sf5hl-pooler.c-7.us-east-1.aws.neon.tech/neondb?sslmode=require
SPRING_DATASOURCE_USERNAME=neondb_owner
SPRING_DATASOURCE_PASSWORD=npg_FSC3Qx4WDApT
